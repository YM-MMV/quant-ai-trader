# .env.example — placeholders only. Copy to .env and fill locally.
# NEVER put real secrets here. NEVER commit your real .env.

# --- Trading mode & safety locks ---
# Allowed modes: research | backtest | paper | mt5_demo | live
TRADING_MODE=paper
# Live trading is disabled by default. Do not enable without reading SAFETY.md.
ALLOW_LIVE_TRADING=false

# --- Risk limits (deterministic, enforced by RiskManager) ---
MAX_DAILY_LOSS=0.0
MAX_OPEN_TRADES=0
MAX_SPREAD_POINTS=0

# --- Symbol allowlist (comma-separated; mapped via config/symbols.yaml) ---
SYMBOL_ALLOWLIST=EURUSD,GBPUSD,XAUUSD

# --- MetaTrader 5 (demo account; leave blank until configured locally) ---
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_TERMINAL_PATH=

# --- OpenBB / data providers (optional, placeholders) ---
OPENBB_PAT=

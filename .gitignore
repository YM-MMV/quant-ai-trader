# Secrets — NEVER commit
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/

# Testing / tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Vendored external repos (cloned locally, not committed)
external/

# Logs & data artifacts
*.log
logs/
data/raw/
data/cache/
data/historical/

# Large local market data — NEVER commit (tens of GB; tick parquet > GitHub's
# 100 MB/file limit). Resampled candles live in data/historical/ (also ignored).
*.parquet
pricer-output-*/

# OS / editor
.DS_Store
.idea/
.vscode/
